# Copy this file to .env and fill in real values. Never commit .env.

# Your Jira Cloud site, e.g. https://yourcompany.atlassian.net
JIRA_BASE_URL=https://shl.atlassian.net/

# The email address you log into Jira with
JIRA_EMAIL=pranav.kumar@shl.com

# Create at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=ATATT3xFfGF0aPNNW4qjv7JI2Mx8-bFlaCy5-I30rBAp7Ef4yGlIZZMGH2RBXq_1ocv6Vm-q1QkAmvaSsSZ58VOnIaBE8-UKYy6SaV2XNo15Z1hb5qfcP7AZWJhs4gYq6f0oajvNd6A9Sj3Pdygh-lBZuLzU73aqnHZE_TNAlgs4p2CJoDXqPbA=292015EA

# Optional: scope search to one project (recommended for a hackathon demo —
# e.g. a test/sandbox project rather than live client tickets)
JIRA_PROJECT_KEYS=SD,DEV,PLAT,CLI,REPORT,UP,TCI

# Optional — Confluence lives at the same Atlassian site as Jira by default
# (JIRA_BASE_URL + "/wiki"), using the same email/token. Only set
# CONFLUENCE_BASE_URL if your Confluence is somewhere different.
CONFLUENCE_BASE_URL=
# Optional: scope Confluence search to specific spaces, comma-separated.
# Leave blank to search every space the token can see.
CONFLUENCE_SPACE_KEYS=https://shl.atlassian.net/wiki/spaces/SPI/overview?homepageId=178585602

# --- AI-Thon shared model gateway ---
# Get this from the AI-Thon organisers — it's your team's shared key, NOT
# a personal Anthropic key. It has a fixed budget, shared across your team.
AITHON_API_KEY=sk-ZKd8cF5bfZpZue3dkHjE7w

# Given in the AI-Thon README — usually you won't need to change this.
AITHON_BASE_URL=https://labs.shl.com/llm-internal/

# Which model this app calls. Options from the AI-Thon README:
#   claude-sonnet-5-aithon   (default here — good general reasoning)
#   gpt-5.6-terra-aithon     (also solid, OpenAI instead of Claude)
#   gpt-5.4-mini-aithon      (cheapest — use if your budget is tight)
#   gpt-5.6-sol-aithon / claude-opus-4-7-aithon (expensive — avoid unless needed)
AITHON_MODEL=claude-sonnet-5-aithon
PORT=3001
ALLOW_INSECURE_TLS=true